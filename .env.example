# ─── Vercel Postgres (set automatically when you add Postgres in Vercel dashboard) ───
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Auth.js / NextAuth ───
# Generate a strong secret: openssl rand -base64 32
AUTH_SECRET=your_secret_here_change_this

# ─── Admin setup (used by scripts/setup-db.ts on first run) ───
ADMIN_EMAIL=admin@westerngatelabs.com
ADMIN_PASSWORD=ChangeMe123!

# ─── App URL ───
NEXTAUTH_URL=https://westerngatelabs.com
# For local dev use: http://localhost:3000

# ─── Optional: Email notifications for contact form ───
# RESEND_API_KEY=
